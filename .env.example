"""NGSAT .env example — copy to .env and fill in real values.

NEVER commit the actual .env file — it contains secrets.
"""

# === Environment ===
NGSAT_ENV=development                    # development / production / backtest
NGSAT_DEBUG=true

# === Database (PostgreSQL) ===
NGSAT_DB_URL=postgresql://username:password@localhost:5432/ngsat
NGSAT_DB_ECHO=false

# === KIS API (Korea Investment & Securities) ===
# Get these from KIS Open API portal
KIS_BASE_URL=https://openapi.koreainvestment.com
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NO=your_account_number
KIS_ACNT_PRDT_CD=your_product_code

# === Risk Management ===
NGSAT_DAILY_LOSS_LIMIT=5.0              # 일일 총손실 한도 (%)
NGSAT_DEFAULT_STOP_LOSS=3.0             # 종목별 기본 손절선 (%)
NGSAT_MAX_STOP_LOSS=5.0                 # 종목별 최대 손절선 (%)

# === Strategy & Policy ===
# ── 매매 결정 임계 ──
NGSAT_BUY_THRESHOLD=0.65                # ML 매수 확률 임계 (0.0~1.0)
NGSAT_SELL_THRESHOLD=0.35               # ML 매도 확률 임계 (0.0~1.0)

# ── 시장 레짐 판정 ──
NGSAT_REGIME_BULL_THRESHOLD=65.0        # ≥ 65점 → 강세장
NGSAT_REGIME_BEAR_THRESHOLD=35.0        # ≤ 35점 → 약세장
NGSAT_REGIME_WEIGHT_MA=35.0             # MA 정렬 가중치
NGSAT_REGIME_WEIGHT_RSI=20.0            # RSI 모멘텀 가중치
NGSAT_REGIME_WEIGHT_BOLLINGER=20.0      # 볼린저 밴드 가중치
NGSAT_REGIME_WEIGHT_CHANGE_RATE=15.0    # 단기 등락률 가중치
NGSAT_REGIME_WEIGHT_VOLUME=10.0         # 거래량 추세 가중치

# ── 종목 스크리너 ──
NGSAT_SCREENER_BULL_MIN_SCORE=60.0      # 강세장 최소 통과 점수
NGSAT_SCREENER_BULL_MAX_CANDIDATES=15   # 강세장 최대 종목 수
NGSAT_SCREENER_NEUTRAL_MIN_SCORE=70.0   # 중립장 최소 통과 점수
NGSAT_SCREENER_NEUTRAL_MAX_CANDIDATES=10
NGSAT_SCREENER_BEAR_MIN_SCORE=80.0      # 약세장 최소 통과 점수
NGSAT_SCREENER_BEAR_MAX_CANDIDATES=5

# ── 모드 전환 (스윙 ↔ 단타) ──
NGSAT_MODE_HIGH_VOL_ATR_PCT=1.5         # ATR ≥ 1.5% → 고변동성(단타)
NGSAT_MODE_LOW_VOL_ATR_PCT=0.5          # ATR ≤ 0.5% → 저변동성(스윙)

# ── 모드별 리스크 ──
NGSAT_MODE_SWING_STOP_LOSS=3.0          # 스윙: 종목 손절선 (%)
NGSAT_MODE_SWING_DAILY_LOSS=5.0         # 스윙: 일일 총손실 한도 (%)
NGSAT_MODE_SWING_POSITION_SIZE=0.10     # 스윙: 1회 투자금 (현금 대비)
NGSAT_MODE_SHORT_STOP_LOSS=1.5          # 단타: 종목 손절선 (%)
NGSAT_MODE_SHORT_DAILY_LOSS=3.0         # 단타: 일일 총손실 한도 (%)
NGSAT_MODE_SHORT_POSITION_SIZE=0.05     # 단타: 1회 투자금 (현금 대비)
NGSAT_MODE_HOLD_STOP_LOSS=3.0           # 홀드: 종목 손절선 (%)
NGSAT_MODE_HOLD_DAILY_LOSS=5.0          # 홀드: 일일 총손실 한도 (%)
NGSAT_MODE_HOLD_POSITION_SIZE=0.0       # 홀드: 1회 투자금 (0=진입금지)

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
